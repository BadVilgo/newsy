# Skopiuj do .env.local i uzupełnij własnymi wartościami.

# Gemini (Google AI Studio -> API key)
GEMINI_API_KEY=

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Klucz service_role — TYLKO serwer (cron). Nigdy nie wystawiać w przeglądarce.
SUPABASE_SERVICE_ROLE_KEY=

# Sekret chroniący endpoint cron. Ustaw tę samą wartość w zmiennych środowiskowych Vercel;
# Vercel Cron automatycznie dołączy nagłówek "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=
